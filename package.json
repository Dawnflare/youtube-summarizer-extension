  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/youtube-summarizer-extension"
  },
  "bugs": {
    "url": "https://github.com/yourusername/youtube-summarizer-extension/issues"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "archiver": "^7.0.1",
    "bestzip": "^2.2.1",
    "copyfiles": "^2.4.1",
    "mkdirp": "^3.0.1",
    "playwright": "^1.40.0",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
