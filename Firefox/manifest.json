{
  "manifest_version": 2,
  "name": "YouTube Summarizer (Dawnflare)",
  "version": "1.0",
  "description": "Summarize YouTube videos with Gemini AI. Adds a button to YouTube to open Gemini with the video URL for instant summaries.",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*", "https://youtube.com/*"],
      "js": ["logging.js", "content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://gemini.google.com/app*"],
      "js": ["logging.js", "gemini_filler.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_title": "Summarize with Gemini",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_security_policy": "script-src 'self'; object-src 'self';",
  "author": "Brian Hare",
  "homepage_url": "https://github.com/Dawnflare/youtube-summarizer-extension",
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-summarizer-extension@haresolutions.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
